        {
          "id": "bfe21000-f0ac-47c8-89a5-f28a3915f1aa",
          "name": "Obtain Access Token",
          "request": {
            "name": "Obtain Access Token",
            "description": {
              "content": "Obtain a token for accessing other 1NCE API resources by using a POST request with a valid username and password combination for a 1NCE user account that has the permission to use the API.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "oauth",
                "token"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": []
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{basicAuthUsername}}"
                },
                {
                  "key": "password",
                  "value": "{{basicAuthPassword}}"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"client_credentials\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
